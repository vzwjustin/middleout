# Strict Claude Code subscription/OAuth passthrough only.
# This proxy intentionally has no API-key mode.
# Do NOT set ANTHROPIC_API_KEY, ANTHROPIC_AUTH_TOKEN, PROXY_ANTHROPIC_API_KEY,
# PROXY_AUTH_MODE, or PROXY_FORCE_API_KEY in the proxy process.

# Upstream Anthropic API. Do not set this to ANTHROPIC_BASE_URL; Claude Code points that to this proxy.
PROXY_UPSTREAM_BASE_URL=https://api.anthropic.com

# Local listener
MIDDLEOUT_HOST=127.0.0.1
MIDDLEOUT_PORT=8787

# Input compression
MIDDLEOUT_INPUT_COMPRESSION=true
MIDDLEOUT_MAX_TEXT_CHARS=12000
MIDDLEOUT_MIN_OMISSION_CHARS=1500
MIDDLEOUT_HEAD_FRACTION=0.55
MIDDLEOUT_COMPRESS_SYSTEM=false
MIDDLEOUT_COMPRESS_TOOL_RESULTS=true

# JL-style near-duplicate detection inside a single request
MIDDLEOUT_JL_DEDUPE=true
MIDDLEOUT_JL_DIMS=512
MIDDLEOUT_JL_SHINGLE_TOKENS=5
MIDDLEOUT_JL_SIMILARITY=0.985
MIDDLEOUT_JL_MIN_CHARS=4000

# Output compression is risky for agent tools; keep off unless manually testing.
MIDDLEOUT_OUTPUT_COMPRESSION=false
MIDDLEOUT_OUTPUT_MAX_TEXT_CHARS=20000

# Logging: stores hashes/stats by default, not prompt text.
MIDDLEOUT_AUDIT=true
MIDDLEOUT_AUDIT_DIR=.middleout-logs
MIDDLEOUT_LOG_TEXT_SAMPLES=false

# ----- Brain proxy: Phase 2/3/4 (cache, providers, cost) -------------------
# All Phase 2+ settings are OFF by default. Enable selectively.

# Phase 1: cache-aware compression of the volatile tail with LLMLingua-2.
# Requires `pip install -e '.[lingua]'` (downloads ~200MB BERT on first use).
BRAIN_LINGUA_ENABLED=false
BRAIN_LINGUA_RATIO=0.5
# BRAIN_LINGUA_MODEL=microsoft/llmlingua-2-bert-base-multilingual-cased-meetingbank

# Auto-stamp cache_control after [system][tools] when the client did not.
BRAIN_AUTO_INSERT_WALL=true

# Phase 2a: L1 exact-match response cache (SHA-256 of normalized payload).
BRAIN_L1_CACHE_ENABLED=false
BRAIN_L1_CACHE_DB=:memory:
BRAIN_L1_CACHE_MAX_ENTRIES=10000
BRAIN_L1_CACHE_MAX_BODY_BYTES=5242880

# Phase 2b: L2 semantic response cache. Backends: in_memory | qdrant.
BRAIN_L2_CACHE_ENABLED=false
BRAIN_L2_SIMILARITY=0.97
BRAIN_L2_BACKEND=in_memory
BRAIN_L2_MAX_ENTRIES=10000
# Qdrant only:
# BRAIN_L2_QDRANT_URL=
# BRAIN_L2_QDRANT_COLLECTION=brain_proxy_l2
# BRAIN_L2_QDRANT_API_KEY=
# Embedder: hash | openai
BRAIN_L2_EMBEDDER=hash
BRAIN_L2_EMBEDDING_DIM=3072
# BRAIN_L2_OPENAI_MODEL=text-embedding-3-large

# Optional per-model/per-endpoint policy router. JSON blob; see policies.py.
# MIDDLEOUT_POLICIES={"v1/messages":{"claude-3-5-haiku":{"max_text_chars":4000}}}

# TOML config file (optional). Lookup order: this var > ./middleout.toml >
# ~/.config/middleout/middleout.toml.
# MIDDLEOUT_CONFIG=./middleout.toml
